# ═══════════════════════════════════════════════
#  ANANSI CITY SERVER EMULATOR — ENVIRONMENT
# ═══════════════════════════════════════════════

# Server Configuration
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Directory where game assets (S3 bucket files) are stored
RESOURCES_DIR=./resources

# ── Supabase Database (Optional — leave empty for in-memory mode) ──
# Create a free Supabase project at https://supabase.com
# Then create a table called "players" with the schema from schema.sql
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
# SUPABASE_ANON_KEY=your-anon-key-here  # alternative to service key

# Set to "true" to force in-memory mode even if Supabase is configured
# DISABLE_DB=false
